  },
  "components": {
    "schemas": {
      "AddUserToOrganisationRequest": {
        "type": "object",
        "required": [
          "user_id",
          "org_id",
          "role_code"
        ],
        "properties": {
          "org_id": {
            "type": "string",
            "format": "uuid"
          },
          "role_code": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "AssignRoleRequest": {
        "type": "object",
        "required": [
          "user_id",
          "role_code"
        ],
        "properties": {
          "role_code": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "AssignRoleResponseBody": {
        "type": "object",
        "required": [
          "assigned"
        ],
        "properties": {
          "assigned": {
            "type": "boolean"
          }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": [
          "current_password",
          "new_password"
        ],
        "properties": {
          "current_password": {
            "type": "string"
          },
          "new_password": {
            "type": "string"
          }
        }
      },
      "CreateOrganisationRequest": {
        "type": "object",
        "required": [
          "name",
          "business"
        ],
        "properties": {
          "business": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "seed_creator_as_owner": {
            "type": "boolean"
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "description": "RFC 7807 problem body returned on all error responses.\n\nAll six stable fields are present in every response; `errors` is included\nonly on validation errors (HTTP 400) and maps field name → list of slugs.",
        "required": [
          "type",
          "title",
          "status",
          "detail"
        ],
        "properties": {
          "detail": {
            "type": "string",
            "description": "Human-readable explanation specific to this occurrence."
          },
          "errors": {
            "type": "object",
            "description": "Field-level validation errors (present only on 400 responses).",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nullable": true
          },
          "instance": {
            "type": "string",
            "description": "URI reference identifying the specific occurrence of the problem.",
            "nullable": true
          },
          "request_id": {
            "type": "string",
            "description": "Correlation ID for request tracing.",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "HTTP status code.",
            "minimum": 0
          },
          "title": {
            "type": "string",
            "description": "Short human-readable summary of the error."
          },
          "type": {
            "type": "string",
            "description": "A URI reference identifying the error type."
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "username_or_email",
          "password"
        ],
        "properties": {
          "password": {
            "type": "string"
          },
          "username_or_email": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": [
          "token",
          "user_id",
          "active_org_id",
          "memberships"
        ],
        "properties": {
          "active_org_id": {
            "type": "string",
            "format": "uuid"
          },
          "memberships": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MembershipDto"
            }
          },
          "token": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "MemberBody": {
        "type": "object",
        "required": [
          "user_id",
          "username",
          "email",
          "role_codes"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "role_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "MembershipDto": {
        "type": "object",
        "required": [
          "org_id",
          "org_name",
          "role_codes"
        ],
        "properties": {
          "org_id": {
            "type": "string",
            "format": "uuid"
          },
          "org_name": {
            "type": "string"
          },
          "role_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "OrganisationBody": {
        "type": "object",
        "required": [
          "id",
          "name",
          "business",
          "role_codes"
        ],
        "properties": {
          "business": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "role_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PagedMembers": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemberBody"
            }
          },
          "next_cursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PagedOrganisations": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganisationBody"
            }
          },
          "next_cursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PasswordResetConfirmBody": {
        "type": "object",
        "required": [
          "token",
          "new_password"
        ],
        "properties": {
          "new_password": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "PasswordResetRequestBody": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "username",
          "email",
          "password",
          "org_id",
          "role_code"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "org_id": {
            "type": "string",
            "format": "uuid"
          },
          "password": {
            "type": "string"
          },
          "role_code": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
